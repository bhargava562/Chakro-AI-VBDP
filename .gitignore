# ===========================
# Chakro Monorepo .gitignore
# ===========================

# -------- OS Files --------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
ehthumbs.db
Icon?

# -------- IDE / Editor --------
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath
.apt_generated
.springBeans
.sts4-cache
*.suo
*.ntvs*
*.njsproj
*.sln
.agent/
.gemini/
*.code-workspace
nbproject/

# -------- Environment Secrets & Credentials --------
# Never commit real secrets — only .example and .development templates
.env
.env.local
.env.production
.env.staging
.env.*.local
env/.env.development
env/.env.production
env/.env.staging
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
credentials.json
service-account*.json

# -------- Logs --------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
hs_err_pid*
replay_pid*

# -------- Docker --------
docker-data/

# -------- Monitoring Data (runtime) --------
monitoring/grafana-data/
monitoring/prometheus-data/

# -------- Java / Maven --------
server/target/
!**/src/main/**/target/
!**/src/test/**/target/
server/.mvn/wrapper/maven-wrapper.jar

# -------- Node / Frontend --------
client/node_modules/
client/dist/
client/dist-ssr/
*.local

# -------- Build / Coverage --------
build/
!**/src/main/**/build/
!**/src/test/**/build/
coverage/
*.lcov
.nyc_output/

# -------- Misc --------
*.bak
*.tmp
*.orig
*.pid
*.seed
*.gz
*.tgz


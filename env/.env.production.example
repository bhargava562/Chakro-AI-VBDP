# =============================================
# Chakro — Production Environment Template
# =============================================
# INSTRUCTIONS:
#   1. Copy this file to .env.production
#      cp env/.env.production.example env/.env.production
#   2. Fill in all values with strong, unique passwords
#   3. NEVER commit .env.production to version control

POSTGRES_DB=chakro
POSTGRES_USER=chakro
POSTGRES_PASSWORD=             # <-- REQUIRED: strong password
POSTGRES_PORT=5432

REDIS_PORT=6379

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

CLIENT_PORT=80

GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=              # <-- REQUIRED: strong password

PROMETHEUS_PORT=9090

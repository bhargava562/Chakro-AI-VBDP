# =============================================
# Chakro — Environment Variables Reference
# =============================================
# Copy this file and rename to .env.production
# Fill in your actual values. NEVER commit .env.production!

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_DB=chakro
POSTGRES_USER=chakro
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- Spring Boot Server ----------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ---------- Client (Nginx) ----------
CLIENT_PORT=80

# ---------- Grafana ----------
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ---------- Prometheus ----------
PROMETHEUS_PORT=9090

# =========================================================================
# Chakro AI VBDP — Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to version control.
# =========================================================================

# ---- Groq AI API ----
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ---- Security & JWT ----
# Generate a secure random string (at least 32 characters)
JWT_SECRET_KEY=your_secure_jwt_secret_key_here
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION=604800000

# ---- Supabase / PostgreSQL Connection ----
SPRING_DATASOURCE_URL=jdbc:postgresql://db.xxx.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_supabase_db_password_here

# ---- Server Configuration ----
SERVER_PORT=8080
LOG_LEVEL_CHAKRO=DEBUG

# ---- Workspace & Storage ----
VBDP_FILE_STORAGE=./generated-proposals
